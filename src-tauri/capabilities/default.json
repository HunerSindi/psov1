{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-write-file",
    "fs:allow-create",
    {
      "identifier": "fs:scope",
      "allow": ["$HOME/**"],
      "deny": []
    },
    "shell:default",
    "http:default"
  ]
}
