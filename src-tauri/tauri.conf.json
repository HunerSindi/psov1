{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "kashiro",

  "version": "0.1.0",
  "identifier": "com.kashiro.app",
  "build": {
    "frontendDist": "http://127.0.0.1:3000",
    "devUrl": "http://127.0.0.1:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "kashiro",
        "width": 800,
        "height": 600,
        "resizable": false,
        "fullscreen": false,
        "maximized": true
      }
    ],

    "security": {
      "csp": null
    }
  },
  "bundle": {
    "externalBin": ["binaries/node"],
    "resources": ["server/**/*"],
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
